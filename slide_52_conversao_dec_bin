decimal = int(input("Decimal: "))

if decimal == 0:
    print("Binário: 0")

else: 
    lista = []
    quociente = decimal
    while quociente != 0:
        quociente = decimal//2
        resto = decimal % 2
        lista.insert(0, resto)
        decimal = quociente

        string = ""
        for i in lista:
            string += str(i)

    print(f"Binário = {string}")